# Git
.git
.gitignore

# Build output — rebuilt inside Docker
.next
out

# Dependencies — reinstalled inside Docker
node_modules

# Local environment files — injected at runtime via docker-compose
.env
.env.local
.env.*.local

# Dev-only compose file
docker-compose.dev.yml

# macOS
.DS_Store

# Editor / IDE
.cursor
.vscode
*.swp
*.swo

# Test artifacts
coverage
playwright-report
test-results

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# TypeScript build info
*.tsbuildinfo

# Media uploads (bind-mounted at runtime, not baked into the image)
public/media
