# -------------------------------------------------------
# ENVIRONMENT VARIABLES — Copy this to .env and fill in values.
# .env is gitignored and must never be committed.
# -------------------------------------------------------

# --- Database ---
# For local dev: matches docker-compose.dev.yml (localhost)
# For production: use the Docker service name as host (db)
DATABASE_URL=postgresql://yazit_user:your_password@localhost:5432/yazit_db

# Production-only: individual values used by docker-compose.yml
POSTGRES_USER=yazit_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=yazit_db

# --- Payload CMS ---
# Must be a long random string (min 32 chars). Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace_with_a_long_random_secret_string

# --- Next.js ---
# Local dev: http://localhost:3000
# Production: https://ybilgin.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- ISR Revalidation ---
# Protects the /api/revalidate endpoint. Generate with: openssl rand -hex 32
REVALIDATION_SECRET=replace_with_strong_random_secret

# --- Node ---
NODE_ENV=development
