# ──────────────────────────────────────────────────────────────────────────────
# YAZIT — Environment Variables
# Copy this file to .env and fill in the real values.
# .env is gitignored and must NEVER be committed.
#
# Generate random secrets with:
#   openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# Full Postgres connection string used by Payload CMS at runtime.
#   Local dev  → host is localhost (DB runs in Docker, port 5432 exposed to host)
#   Production → host is "db" (the Docker Compose service name on yazit_network)
DATABASE_URL=postgresql://yazit_user:your_password@localhost:5432/yazit_db

# Individual credentials used by the db service in docker-compose.yml
# to initialise the PostgreSQL container on first run.
POSTGRES_USER=yazit_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=yazit_db

# ── Payload CMS ───────────────────────────────────────────────────────────────

# Long random string used to sign JWTs and encrypt sensitive fields.
# Min 32 chars.  Changing this invalidates all existing admin sessions.
PAYLOAD_SECRET=replace_with_a_long_random_secret_string

# ── Next.js ───────────────────────────────────────────────────────────────────

# The public-facing URL of the site (no trailing slash).
#   Local dev  → http://localhost:3000
#   Production → https://ybilgin.com
# Used by next/image remote patterns and Payload's SEO plugin for canonical URLs.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── ISR Revalidation ─────────────────────────────────────────────────────────

# Protects the POST /api/revalidate endpoint from unauthorised calls.
# Include this in the Authorization header: Bearer <token>
REVALIDATION_SECRET=replace_with_strong_random_secret

# ── Node ──────────────────────────────────────────────────────────────────────

# Set to "production" inside the Docker container (handled by docker-compose.yml).
# Leave as "development" for local pnpm dev workflow.
NODE_ENV=development
